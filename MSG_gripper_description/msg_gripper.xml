<mujoco model="msg_gripper">
  <compiler angle="radian" autolimits="true" meshdir="assets"/>

  <option integrator="implicitfast"/>

  <!-- Default -->
  <default>
    <default class="MSG_gripper">
      <joint armature="0.01" damping="0.2" frictionloss="0"/>
      <position forcerange="-50 50" ctrlrange="-0.0525 0" kp="1000"/>
    </default>
  </default>

  <asset>
    <mesh name="gripper" file="gripper_MSG.STL" scale="1 1 1"/>
    <mesh name="jaw1" file="jaw1_MSG.STL" scale="1 1 1"/>
    <mesh name="jaw2" file="jaw2_MSG.STL" scale="1 1 1"/>
  </asset>

  <worldbody>
    <body name="gripper">
      <inertial pos="-0.0064247 0.000282669 -0.0695192" quat="0.700694 0.703416 0.0814468 -0.0871836" mass="0.347623" diaginertia="0.000141544 0.000129702 2.45301e-05"/>
      <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="gripper"/>

      <!-- Camera center -->
      <body name="camera_center" pos="0.0 -0.09 0.1">
        <geom size="0.005 0.005 0.005" pos="0. 0. 0."
            contype="0" conaffinity="0"
            type="box" rgba="1.00 0.00 0.0 0" />
        <camera name="egocentric" pos="0 0 0" xyaxes="-1 0 0 0 0 1" fovy="90" />
      </body>

      <body name="tcp_link" pos="0 -0.22 0">
        <site name="tcp"
              pos="0 0 0"
              size="0.005"
              rgba="1 0 0 0"/>
        <geom type="capsule" fromto="0 0 -0.5 0 0 0.5" size="0.01" rgba="1.0 0.2 0.2 0.0" contype="0" conaffinity="0"/>
      </body>

      <body name="jaw1" pos="0.02835 0 -0.1409" quat="1.34924e-11 3.67321e-06 -1 -3.67321e-06">
        <inertial pos="0.0016848 -0.059152 -0.053962" quat="0.98197 0.171875 0.0156016 -0.0771347" mass="0.020716" diaginertia="1.62283e-05 1.1144e-05 6.39767e-06"/>
        <joint name="jaw1_JOINT" pos="0 0 0" axis="0 -1 0" type="slide" range="-0.0525 0" class="MSG_gripper"/>
        <geom type="mesh"
              mesh="jaw1"
              rgba="0.29804 0.29804 0.29804 1"
              friction="1.2 0.3 0.001"
              solref="0.002 1"
              solimp="0.9 0.95 0.001"/>
      </body>

      <body name="jaw2" pos="0.02835 0 -0.1409" quat="1.34924e-11 3.67321e-06 -1 -3.67321e-06">
        <inertial pos="0.0016605 0.059282 -0.050421" quat="0.994665 0.0689527 0.0499866 0.0582113" mass="0.020666" diaginertia="1.60561e-05 1.06891e-05 6.58103e-06"/>
        <joint name="jaw2_JOINT" pos="0 0 0" axis="0 -1 0" type="slide" range="0 0.0525" class="MSG_gripper"/>
        <geom type="mesh"
              mesh="jaw2"
              rgba="0.29804 0.29804 0.29804 1"
              friction="1.2 0.3 0.001"
              solref="0.002 1"
              solimp="0.9 0.95 0.001"/>
      </body>

    </body>
  </worldbody>

  <!-- Gripper fingers are parallel -->
  <equality>
    <joint joint1="jaw2_JOINT" joint2="jaw1_JOINT" polycoef="0 -1 0 0 0"/>
  </equality>

  <!-- Define actuators -->
  <actuator>
    <position name="actuator_jaw" joint="jaw1_JOINT" class="MSG_gripper"/>
  </actuator>

</mujoco>
